# LLM-Rosetta Gateway 可选预填配置
# /admin/ 管理面板保存后的配置会写入 ./config/config.jsonc，无需重启容器

# ================================
# OpenAI 可选默认值
# ================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ================================
# Anthropic 可选默认值
# ================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ================================
# Google GenAI 可选默认值
# ================================
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
