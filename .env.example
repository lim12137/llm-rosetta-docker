# Published image to deploy. Override only when testing another tag.
LLM_ROSETTA_IMAGE=ghcr.io/lim12137/llm-rosetta-docker:latest

# Host port for the gateway and admin panel.
LLM_ROSETTA_PORT=8765

# Optional provider defaults used by the baked config.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
