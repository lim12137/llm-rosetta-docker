# LLM-Rosetta 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# ================================
# OpenAI 配置
# ================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ================================
# Anthropic 配置
# ================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ================================
# Google GenAI 配置
# ================================
GOOGLE_API_KEY=

# ================================
# 服务配置
# ================================
LOG_LEVEL=info
PORT=8000
HOST=0.0.0.0

# ================================
# 安全配置
# ================================
# 是否启用 API 密钥验证
REQUIRE_AUTH=false

# 允许的 API 密钥（逗号分隔）
ALLOWED_API_KEYS=

# 速率限制
RATE_LIMIT_ENABLED=true
REQUESTS_PER_MINUTE=60
REQUESTS_PER_HOUR=1000

# ================================
# 转换配置
# ================================
# 默认输入格式（auto, openai_chat, openai_responses, anthropic, google）
DEFAULT_INPUT_FORMAT=auto

# 默认输出格式
DEFAULT_OUTPUT_FORMAT=openai_chat

# 是否启用工具调用
TOOL_CALLING_ENABLED=true

# 是否启用流式响应
STREAMING_ENABLED=true
