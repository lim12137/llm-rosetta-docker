{
  // LLM-Rosetta Gateway configuration
  // This file is persisted under ./config/config.jsonc and can be edited live in /admin/.
  "providers": {
    "openai-default": {
      "type": "openai_chat",
      "api_key": "",
      "base_url": "https://api.openai.com/v1"
    },
    "anthropic-default": {
      "type": "anthropic",
      "api_key": "",
      "base_url": "https://api.anthropic.com"
    },
    "google-default": {
      "type": "google",
      "api_key": "",
      "base_url": "https://generativelanguage.googleapis.com"
    }
  },
  "models": {
    "gpt-4o": "openai-default",
    "gpt-4o-mini": "openai-default",
    "claude-sonnet-4-20250514": "anthropic-default",
    "gemini-2.0-flash": "google-default"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  }
}
