{
  // Default config baked into the image.
  // On first container start, the entrypoint seeds this file to /config/config.jsonc
  // when no external config is mounted.
  "providers": {
    "openai_chat": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "${OPENAI_BASE_URL}"
    },
    "openai_responses": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "${OPENAI_BASE_URL}"
    },
    "anthropic": {
      "api_key": "${ANTHROPIC_API_KEY}",
      "base_url": "${ANTHROPIC_BASE_URL}"
    },
    "google": {
      "api_key": "${GOOGLE_API_KEY}",
      "base_url": "${GOOGLE_BASE_URL}"
    }
  },
  "models": {
    "gpt-4o": "openai_chat",
    "gpt-4o-mini": "openai_chat",
    "gpt-4.1": "openai_chat",
    "gpt-4.1-mini": "openai_chat",
    "gpt-4.1-nano": "openai_chat",
    "claude-sonnet-4-20250514": "anthropic",
    "claude-3-5-haiku-20241022": "anthropic",
    "gemini-2.0-flash": "google",
    "gemini-2.5-pro": "google",
    "gemini-2.5-flash": "google"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8765
  }
}
